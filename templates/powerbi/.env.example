# ============================================================================
# Power BI Data Source Configuration
# ============================================================================

# Database Connection
DB_SERVER=your_server_here
DB_DATABASE=your_database_here
DB_USERNAME=your_username_here

# SQL Server (if applicable)
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_TRUSTED_CONNECTION=yes

# API Keys (if using custom data sources)
API_KEY=your_api_key_here
API_ENDPOINT=https://api.example.com

# Azure services (if applicable)
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id

# SharePoint/OneDrive (if applicable)
SHAREPOINT_SITE=https://your-tenant.sharepoint.com/sites/your-site
